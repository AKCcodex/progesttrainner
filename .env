# --- AI Provider ---
# Default is Ollama. Swap to: openai | anthropic | gemini | openai_compatible
AI_PROVIDER=ollama

# Ollama (Cloud OR local server). If OLLAMA_API_KEY is empty, requests go unauthenticated
# (suitable for local http://localhost:11434).
OLLAMA_BASE_URL=https://your-ollama-endpoint
OLLAMA_API_KEY=your_api_key
OLLAMA_MODEL=gemma3:4b

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI-compatible (LM Studio, vLLM, llama.cpp server, etc.)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# --- App ---
DATABASE_URL=postgresql+psycopg://coach:coach@postgres:5432/coach
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
JWT_EXPIRES_MIN=10080

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=8742685413:AAFLbj4RaytD_RpVds7JSO3oISviMkTYxNM
# Long-lived token used by the bot process to call protected internal endpoints.
INTERNAL_BOT_TOKEN=change-me-in-prod

# --- Frontend (used by frontend container build) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1